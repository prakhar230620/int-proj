# Server
SERVER_PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/noteskeeper?retryWrites=true&w=majority

# Security
JWT_SECRET=your_super_secret_jwt_key_here

# Redis Cache (Optional - will bypass if not available but recommended for performance)
REDIS_URL=redis://localhost:6379

# AI Integration (Optional)
GEMINI_API_KEY=your_gemini_api_key_here
